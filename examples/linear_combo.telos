// linear_combo.telos — sum of a linear expression: Σ (2*i + 3)
//
// Body is 2*i + 3, a degree-1 polynomial.
// Σ(i=0..n-1) (2i+3) = 2*n*(n-1)/2 + 3*n = n*(n-1) + 3*n = n^2 + 2*n

int linear_combo(int n) {
    int s = 0;
    for (int i = 0; i < n; i++) {
        s += 2 * i + 3;
    }
    return s;
}
