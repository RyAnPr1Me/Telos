// multi_fn.telos — multiple functions in one file
//
// Demonstrates that the compiler handles several function definitions.

int double_sum(int n) {
    int a = 0;
    for (int i = 0; i < n; i++) {
        a += i;
    }
    int b = 0;
    for (int j = 0; j < n; j++) {
        b += j;
    }
    return a + b;
}

int cube_sum(int n) {
    int s = 0;
    for (int i = 0; i < n; i++) {
        s += i * i * i;
    }
    return s;
}
