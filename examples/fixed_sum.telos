// fixed_sum.telos — sum of 0..9 (all inputs compile-time constant)
//
// Because start=0 and end=10 are both constants, the compiler evaluates
// the reduction entirely at compile time and emits the literal 45.

int fixed_sum() {
    int s = 0;
    for (int i = 0; i < 10; i++) {
        s += i;
    }
    return s;
}
